# Ignore everything by default — explicit allowlist below
*

# ── Directories to traverse ──────────────────────────────
!hooks/
!agents/
!commands/
!get-shit-done/
!cache/
!plugins/

# ── All content within tracked directories ───────────────
!hooks/**
!agents/**
!commands/**
!get-shit-done/**
!cache/**

# ── Specific plugin config files only (not cache/ or marketplaces/) ──
!plugins/installed_plugins.json
!plugins/known_marketplaces.json
!plugins/blocklist.json

# ── Root-level config files ───────────────────────────────
!.gitignore
!README.md
!CLAUDE.md
!*.md
!settings.json
!package.json
!policy-limits.json
!gsd-file-manifest.json
!*.sh

# ── Always exclude (must come last to override allowlist) ──
.DS_Store
**/.DS_Store

# ── Never commit secrets ──────────────────────────────────
.env
.env.*
*credentials*
*secrets*
*secret*
*_key
*_token
*.pem
*.key
*.p12
*.pfx
