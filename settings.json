            "type": "command",
            "command": "node \"/Users/tuomasleppanen/.claude/hooks/gsd-context-monitor.js\"",
            "timeout": 10
          }
        ]
      },
      {
        "hooks": [
          {
            "type": "command",
            "command": "node \"/Users/tuomasleppanen/.claude/hooks/claude-config-backup.js\""
          }
        ]
